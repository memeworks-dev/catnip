# Catnip environment configuration
# ---------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Every variable below maps to claude.md §15. Variables prefixed NEXT_PUBLIC_
# are exposed to the browser bundle — never put a secret behind that prefix.
#
# Pricing and provider defaults are pre-filled with the spec values; everything
# else is a placeholder for a managed-service credential.

# --- Generation (claude.md §5, §15) ---
GEMINI_API_KEY=                       # Google nano banana (Gemini image) — primary generation provider
IMAGE_PROVIDER=nano_banana            # active generation provider key (see lib/generation)
FAL_KEY=                              # fal.ai — fallback provider

# --- Moderation (claude.md §8) ---
MODERATION_PROVIDER=google_vision     # active moderation provider key (see lib/moderation)
GOOGLE_VISION_API_KEY=                # Google Vision SafeSearch + face age check

# --- Jobs / rate limit / cache (claude.md §5) ---
QSTASH_TOKEN=                         # Upstash QStash — durable async generation jobs
UPSTASH_REDIS_REST_URL=               # Upstash Redis — quota, rate limits, spend-cap reservations
UPSTASH_REDIS_REST_TOKEN=

# --- Storage (claude.md §5, §13) ---
R2_ACCOUNT_ID=                        # Cloudflare R2 (S3-compatible) — generated images + share cards
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Share cards / domains (claude.md §2, §2A, §9) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000   # canonical app URL, used for share cards + absolute links
ROOT_DOMAIN=catnip.io                       # apex domain for *.catnip.io per-toy subdomains

# --- Custom domains: Vercel Domains API (claude.md §2A) ---
VERCEL_API_TOKEN=                     # token used to attach/verify/remove custom domains
VERCEL_PROJECT_ID=                    # the Catnip Vercel project (prj_… or the project name)
VERCEL_TEAM_ID=                       # only if the project lives under a team

# --- Cron (claude.md §2A, §12) ---
CRON_SECRET=                          # Vercel Cron sends `Authorization: Bearer <this>`; locks /api/cron/*

# --- Analytics (claude.md §10) ---
NEXT_PUBLIC_POSTHOG_KEY=              # PostHog project key (run/share/return events)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- Data / auth / payments / email / errors (claude.md §5) ---
DATABASE_URL=                         # Postgres (Neon/Supabase). e.g. postgresql://user:pass@host:5432/catnip?schema=public
DIRECT_URL=                           # optional: direct (non-pooled) URL for migrations. Required if DATABASE_URL is a pooler that can't migrate (e.g. Supabase :6543)
CLERK_SECRET_KEY=                     # Clerk — dashboard auth (server)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=    # Clerk (browser)
# Clerk routing — point at our local sign-in/up pages and back to the dashboard.
# When Clerk is unset, the dashboard runs dev-open (no auth).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
STRIPE_SECRET_KEY=                    # Stripe — lifetime, subscription, top-ups
STRIPE_WEBHOOK_SECRET=                # Stripe webhook signature verification
RESEND_API_KEY=                       # Resend — transactional email
SENTRY_DSN=                           # Sentry — error tracking
NEXT_PUBLIC_TURNSTILE_SITE_KEY=       # Cloudflare Turnstile (browser widget)
TURNSTILE_SECRET_KEY=                 # Turnstile server-side verification

# --- Pricing (claude.md §11) ---
GENERATION_MARKUP=2.5                 # charged_usd = cost_usd * markup
FREE_RUNS_PER_TOY=50                  # first N runs per toy are free (charged 0, cost still logged)
DEFAULT_PER_VISITOR_QUOTA=3           # default free runs per visitor
LIFETIME_STARTING_CREDIT_USD=         # starting free-credit pool for $420 lifetime buyers
